{
  "name": "tanktroubleaddons",
  "version": "2.5.1",
  "description": "TankTroubleAddons — the go-to extension for all your mayhem needs!",
  "scripts": {
    "build:prod": "gulp destroy && gulp --state=production --target=mv3 && gulp --state=production --target=mv2",
    "build:dev": "gulp --state=dev --target=mv3 && gulp --state=dev --target=mv2",
    "dev": "gulp watch --state=dev --target=mv3",
    "dev:mv3": "gulp watch --state=dev --target=mv3",
    "dev:mv2": "gulp watch --state=dev --target=mv2",
    "clean": "gulp destroy",
    "lint": "eslint . --ext .ts,.js",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asger-finding/TankTroubleAddons.git"
  },
  "author": "Asger Finding",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/asger-finding/TankTroubleAddons/issues"
  },
  "homepage": "https://github.com/asger-finding/TankTroubleAddons#readme",
  "devDependencies": {
    "@kesills/eslint-config-airbnb-typescript": "^20.0.0",
    "@stylistic/eslint-plugin": "^2.13.0",
    "@types/chrome": "^0.1.37",
    "@types/jquery": "^3.5.32",
    "@typescript-eslint/parser": "^8.27.0",
    "autoprefixer": "^10.4.21",
    "del": "^8.0.1",
    "esbuild": "^0.27.3",
    "eslint": "^8.57.1",
    "eslint-config-raven": "^1.0.3",
    "eslint-plugin-jsdoc": "^50.6.8",
    "gulp": "^5.0.1",
    "gulp-changed": "^5.0.4",
    "gulp-htmlmin": "^5.0.1",
    "gulp-if": "^3.0.0",
    "gulp-json-editor": "^2.6.0",
    "gulp-postcss": "^10.0.0",
    "gulp-replace": "^1.1.4",
    "gulp-sass": "^6.0.1",
    "gulp-yaml": "^2.0.4",
    "postcss": "^8.5.3",
    "sass-embedded": "^1.86.0",
    "sharp": "^0.34.5",
    "tiny-lr": "^2.0.0",
    "typescript": "^5.8.2",
    "yargs": "^18.0.0"
  },
  "dependencies": {
    "but-unzip": "^0.1.10",
    "discord_emoji": "github:asger-finding/discord_emoji",
    "iso-8859-15": "^3.0.4",
    "match-sorter": "^8.2.0",
    "maxrects-packer": "^2.7.3",
    "micromark": "^4.0.2",
    "micromark-extension-gfm-autolink-literal": "^2.1.0",
    "webext-sync": "^2.0.4"
  }
}
